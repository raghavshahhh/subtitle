# Production Environment Variables for Backend
# Copy these to your hosting platform (Railway, Render, etc.)

# Database Configuration
DATABASE_URL=postgresql://username:password@host:5432/subtitleai_production

# Redis Configuration
REDIS_URL=redis://username:password@host:6379

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Cloudflare R2 Storage
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your-r2-access-key
R2_SECRET_KEY=your-r2-secret-key
R2_BUCKET=subtitleai-production

# AI Services
GEMINI_API_KEY=AIzaSyYour-Gemini-API-Key
OPENAI_API_KEY=sk-your-openai-api-key

# Payment Gateway
RAZORPAY_KEY_ID=rzp_live_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Security
SECRET_KEY=your-super-secret-jwt-key-minimum-32-characters-long
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# CORS Configuration
ALLOWED_ORIGINS=https://subtitleai.com,https://www.subtitleai.com

# File Upload Configuration
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=2147483648
ALLOWED_VIDEO_TYPES=video/mp4,video/quicktime,video/x-msvideo,video/x-matroska,video/webm

# Application Configuration
DEBUG=False
ENVIRONMENT=production
LOG_LEVEL=INFO

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=200

# Monitoring
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
ENABLE_METRICS=true

# Email Configuration (Optional)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Webhook Configuration
WEBHOOK_SECRET=your-webhook-secret-key