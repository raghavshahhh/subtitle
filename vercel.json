{
  "buildCommand": "cd subtitleai/frontend && npm install && npm run build",
  "outputDirectory": "subtitleai/frontend/.next",
  "devCommand": "cd subtitleai/frontend && npm run dev",
  "installCommand": "cd subtitleai/frontend && npm install",
  "framework": "nextjs",
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://your-backend-url.com/api/:path*"
    }
  ]
}
